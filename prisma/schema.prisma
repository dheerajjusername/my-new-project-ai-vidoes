// Prisma schema for the AI video ads platform.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  // bcrypt hash of the user's password (null only for legacy rows).
  passwordHash String?
  // Credit balance. Every paid action (image/video/voice generation)
  // deducts credits; new users start with a free allowance.
  credits      Int         @default(100)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  characters Character[]
  projects   Project[]
}

model Character {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  // The text description the character was generated from (appearance, age, style...)
  description     String
  // URLs of the 5 reference images (different angles) generated by Nano Banana.
  // These are passed to Veo on every shot so the face stays consistent.
  referenceImages String[]
  // ElevenLabs voice used whenever this character speaks (consistent voice
  // across every video, like the face).
  voice           String    @default("Rachel")
  // For UGC ads: a composited "anchor" image where the person holds the
  // product, generated from the person photo + product photo. Passed to
  // the video model so the person-with-product stays consistent.
  compositeAnchor String?
  status          CharacterStatus @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  projects        Project[]

  @@index([userId])
}

model Project {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional: a project can be made without a saved character (the character
  // is then just described in the brief/prompts and images are text-to-image).
  characterId   String?
  character     Character?    @relation(fields: [characterId], references: [id])
  title         String
  // What the user wants to advertise / the creative brief they typed in.
  brief         String
  format        VideoFormat
  // Free-text description of the format when format = CUSTOM.
  customFormat  String?
  // "16:9" (landscape) or "9:16" (vertical/reels).
  aspectRatio   String        @default("16:9")
  // Art style for generated images: realistic, cinematic, anime, cartoon,
  // pixar, watercolor, comic (see src/lib/image-styles.ts).
  imageStyle    String        @default("realistic")
  // Transition between static images: "fade" (black dip), "fadewhite", "cut".
  transition    String        @default("fade")
  // Talking format: the finalized first-frame / scene image that every
  // dialogue clip is animated from (generated, uploaded, or made from a
  // reference the user provides).
  sceneImageUrl String?
  // Narration script (used by static/motion formats to drive the voiceover
  // and the number of images).
  narrationScript String?
  // Word-level timestamps of the voiceover (JSON: [{ text, start, end }]),
  // used to time each static image to the exact words it illustrates.
  voiceoverWords String?
  // Optional pronunciation fixes for the voiceover, stored as a JSON array of
  // { from, to } — each `from` is respelled to `to` before TTS.
  pronunciationFixes String?
  status        ProjectStatus @default(DRAFT)
  // URL of the ElevenLabs voiceover audio, once generated.
  voiceoverUrl  String?
  // URL of the final stitched video (after FFmpeg), once ready.
  finalVideoUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  shots         Shot[]

  @@index([userId])
  @@index([characterId])
}

model Shot {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Position of this shot in the final video (0, 1, 2, ...).
  orderIndex Int
  // Building block: VIDEO (animated with Veo/Kling) or IMAGE (a still,
  // later given a Ken Burns pan/zoom by FFmpeg).
  type       ShotType   @default(VIDEO)
  // Camera framing hint the Creative Director chose (e.g. "close-up",
  // "wide shot"). Woven into the prompt; also useful for the UI.
  cameraAngle String?
  // The full prompt sent to the video model for this shot.
  prompt     String
  // For static images: the portion of the narration this image illustrates.
  // Used to time the image to exactly those words in the voiceover.
  narrationText String?
  // For talking clips: which character speaks this line (e.g. "Farmer").
  speaker    String?
  // Exact words the character speaks in this shot (null = no dialogue).
  // Spoken via ElevenLabs and lip-synced onto the clip with VEED.
  dialogue   String?
  // ISO 639-1 language of the dialogue, e.g. "hi" or "en".
  dialogueLanguage String?
  // Which model generates this shot, e.g. "veo-3.1-lite".
  model      String     @default("veo-3.1-lite")
  status     ShotStatus @default(PENDING)
  // URL of the generated clip, once ready.
  videoUrl   String?
  // URL of the ElevenLabs audio generated for the dialogue, if any.
  audioUrl   String?
  // Planned duration of the clip in seconds.
  durationSec Int?
  // Error message from the last failed generation attempt, if any.
  lastError  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([projectId, orderIndex])
  @@index([projectId])
}

enum CharacterStatus {
  PENDING    // just created, reference images not generated yet
  GENERATING // Nano Banana is generating the 5 reference images
  READY      // all reference images ready, character usable in projects
  FAILED     // image generation failed
}

enum VideoFormat {
  TALKING             // single scene, character speaks to camera
  MOTION_STORYTELLING // multi-shot story with motion
  STATIC_STORYTELLING // narrated story over still shots
  TALKING_MICRODRAMA  // short dramatic dialogue scenes
  UGC_PRODUCT_AD      // creator-style product ad
  CUSTOM              // user-described format (see customFormat)
}

enum ProjectStatus {
  DRAFT              // project created, shot list not generated yet
  PLANNING           // Claude is generating the scene-by-scene shot list
  READY_TO_GENERATE  // shot list ready, waiting for user to start generation
  GENERATING         // shots are being generated
  STITCHING          // FFmpeg is combining clips + voiceover
  COMPLETED          // final video ready
  FAILED             // something went wrong
}

enum ShotStatus {
  PENDING    // not generated yet
  GENERATING // Veo is generating this clip
  COMPLETED  // clip ready
  FAILED     // generation failed (can be retried individually)
}

enum ShotType {
  VIDEO // animated clip (Veo / Kling)
  IMAGE // still image (Ken Burns pan/zoom applied at stitch time)
}
