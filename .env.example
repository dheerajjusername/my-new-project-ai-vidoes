# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Google Gemini API key — used for Veo 3.1 Lite (video) and Nano Banana 2 (images)
GEMINI_API_KEY=""

# Anthropic Claude API key — used to turn a brief into a scene-by-scene shot list
ANTHROPIC_API_KEY=""

# ElevenLabs API key — used for voiceover generation
ELEVENLABS_API_KEY=""
