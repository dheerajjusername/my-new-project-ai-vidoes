# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (used by Prisma) — e.g. from neon.tech
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# fal.ai API key — one key for Veo 3.1 Lite (video), Nano Banana (character
# reference images) and ElevenLabs TTS (voiceover). Get it at fal.ai
FAL_KEY=""

# Anthropic Claude API key — used to turn a brief into a scene-by-scene shot list
ANTHROPIC_API_KEY=""
